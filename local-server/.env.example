# Featherless AI — get your key at https://featherless.ai
FEATHERLESS_API_KEY=your_featherless_api_key_here

# Model to use — swap for a larger one if you want better quality:
#   NousResearch/Meta-Llama-3.1-8B-Instruct   (fast, good for demos)
#   meta-llama/Meta-Llama-3.1-70B-Instruct    (slower, higher quality)
FEATHERLESS_MODEL=NousResearch/Meta-Llama-3.1-8B-Instruct

# Port for the local server (default: 3001)
PORT=3001
